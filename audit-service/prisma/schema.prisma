generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id         String   @id @default(uuid())
  eventType  String
  userId     String?
  productId  String?
  payload    Json?
  emittedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([productId])
  @@index([createdAt])
}
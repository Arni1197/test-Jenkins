generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id              String   @id @default(uuid())
  eventId         String?  @unique
  eventType       String
  userId          String?
  productId       String?
  requestId       String?
  sourceService   String?
  sourceTransport String?
  topic           String?
  entityType      String?
  entityId        String?
  payload         Json?
  emittedAt       DateTime?
  createdAt       DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([productId])
  @@index([requestId])
  @@index([sourceService])
  @@index([sourceTransport])
  @@index([topic])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}
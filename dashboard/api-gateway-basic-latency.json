      "targets": [
        {
          "expr": "sum(sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"api-gateway-.*\", container!=\"POD\", image!=\"\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cores"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
